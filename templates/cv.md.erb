\cvname{<%= title %>}
<% unless blank?(headline) -%>
\cvheadline{<%= headline %>}
<% end -%>
<% unless profile_links.empty? -%>
\cvcontact{<%= profile_links.map { |link| "\\href{#{link["url"]}}{#{link["label"]}}" }.join("\\enspace{}|\\enspace{}") %>}
<% end -%>
<% unless blank?(email) && blank?(city_country) -%>
\cvcontact{<%= [email, city_country].reject { |item| blank?(item) }.join("\\enspace{}|\\enspace{}") %>}
<% end -%>
\vspace{-0.65em}

<% unless blank?(education["items"]) -%>
## <%= education["title"] || labels[:education] %>

<% (education["items"] || []).each do |item| -%>
**<%= item["title"] %>** \hfill \cvdate{<%= item["date"] %>}\
<%= item.dig("school", "name") %><% unless blank?(item["content"]) %>\
<%= compact_markdown(item["content"]).gsub(/\AThesis:\s*/, "Thesis: ") %><% end %>

\vspace{0.3em}
<% end -%>
<% end -%>

<% unless blank?(skills["sets"]) && blank?(skills["stack"]) -%>
## <%= skills["title"] || labels[:skills] %>

<% (skills["sets"] || []).each do |skill| -%>
**<%= skill["title"] %>:** <%= skill["description"] %>\
<% end -%>
<% unless blank?(skills["stack"]) -%>

**<%= labels[:stack] %>:** <%= skills["stack"].map { |item| item["name"] }.join(", ") %>
<% end -%>
<% end -%>

<% unless blank?(experience["items"]) -%>
## <%= experience["title"] || labels[:experience] %>

<% (experience["items"] || []).each do |company| -%>
<% (company["jobs"] || []).each do |job| -%>
<% employer = company_parts(company, job) -%>
\Needspace{8\baselineskip}
**<%= job["name"] %>** \hfill \cvdate{<%= job["date"] %>}\
<%= employer[:company] %><% unless blank?(employer[:partner]) %>\
<%= partnership_label %> <%= employer[:partner] %><% end %><% unless blank?(job["country"]) %>\
\cvlocation{<%= strip_emoji(job["country"]) %>}<% end %>

<%= compact_markdown(job["content"]) %>

\vspace{0.5em}
<% end -%>
<% end -%>
<% end -%>

<% unless blank?(tools["items"]) -%>
## <%= tools["title"] || labels[:tools] %>

<% (tools["items"] || []).each do |item| -%>
**<% if item["url"] %>[<%= item["title"] %>](<%= item["url"] %>)<% else %><%= item["title"] %><% end %>**
\cvpadstart{}<%= item["content"] %>

\vspace{0.3em}
<% end -%>
<% end -%>

<% unless blank?(publications["items"]) -%>
## <%= publications["title"] || labels[:publications] %>

<% (publications["items"] || []).each do |item| -%>
<% link = item["doi"] || item["url"] -%>
**<% if link %>[<%= item["title"] %>](<%= link %>)<% else %><%= item["title"] %><% end %>**
\cvpadstart{}<%= item["authors"].to_s.sub(/\.+\z/, "") %>\
\hspace*{1em}*<%= item["venue"] %>*\
\hspace*{1em}\cvmetadata{<%= [item["type"], item["year"], item["language"]].reject { |value| blank?(value) }.join(" \\textperiodcentered{} ") %>}

\vspace{0.45em}
<% end -%>
<% end -%>
